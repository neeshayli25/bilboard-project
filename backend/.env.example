PORT=5000
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/cdbms?retryWrites=true&w=majority
JWT_SECRET=replace_with_long_random_secret
JWT_EXPIRE=7d
PUBLIC_APP_URL=http://localhost:5173
# Optional public API origin if your backend itself has its own public domain.
# Leave this blank when your public frontend host already proxies /api to the backend.
PUBLIC_API_URL=
FRONTEND_URL=http://localhost:5173
WEBAUTHN_RP_NAME=CDBMS
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:5173
ALLOW_EMAIL_PREVIEW=true
# Server sender email for signup verification and password-reset links.
EMAIL_USER=your_sender_gmail@gmail.com
# Gmail App Password for the sender email above. This is not the user's app login password.
EMAIL_APP_PASSWORD=your_16_character_gmail_app_password
EMAIL_FROM_NAME=CDBMS Support
DEMO_PAYMENT_MODE=false
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx
STRIPE_CONNECTED_ACCOUNT_ID=acct_xxxxxxxxxxxxx
ADMIN_NAME=Admin Nisha
ADMIN_EMAIL=your_admin_email@example.com
ADMIN_PASSWORD=replace_with_strong_admin_password
ADMIN_PHONE=03xxxxxxxxx
ADMIN_ORGANIZATION=CDBMS
